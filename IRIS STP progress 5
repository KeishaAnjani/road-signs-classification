0.8845\n🌟 Base Model terbaik baru disimpan! (F1 naik menjadi: 0.8845)\n","output_type":"stream"},{"name":"stderr","text":"                                                                                 \r","output_type":"stream"},{"name":"stdout","text":"✅ Epoch 4 Selesai | Avg Loss: 0.0576 | F1 Score: 0.8156\n","output_type":"stream"},{"name":"stderr","text":"                                                                                 \r","output_type":"stream"},{"name":"stdout","text":"✅ Epoch 5 Selesai | Avg Loss: 0.0678 | F1 Score: 0.9229\n🌟 Base Model terbaik baru disimpan! (F1 naik menjadi: 0.9229)\n\n==================================================\n📊 FINAL CLASSIFICATION REPORT (BASE MODEL) 📊\n==================================================\n              precision    recall  f1-score   support\n\ntrafficlight       0.90      0.98      0.94       170\n  speedlimit       0.97      1.00      0.98       783\n   crosswalk       0.82      0.95      0.88       200\n        stop       0.85      0.92      0.88        91\n\n   micro avg       0.93      0.98      0.95      1244\n   macro avg       0.88      0.97      0.92      1244\nweighted avg       0.93      0.98      0.95      1244\n\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1800x500 with 4 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":5},{"cell_type":"code","source":"import numpy as np\n\n# --- FUNGSI HELPER: DETEKSI WARNA LAMPU LALU LINTAS (HSV) ---\ndef detect_traffic_light_color(img_rgb, bbox):\n    \"\"\"\n    Menebak warna lampu lalu lintas menggunakan rentang warna HSV.\n    img_rgb: Gambar dalam format RGB (numpy array)\n    bbox: Koordinat [xmin, ymin, xmax, ymax]\n    \"\"\"\n    xmin, ymin, xmax, ymax = map(int, bbox)\n    \n    # Ambil potongan gambar (crop) khusus di area kotak pembatas\n    crop_img = img_rgb[ymin:ymax, xmin:xmax]\n    \n    if crop_img.size == 0:\n        return \"Unknown\"\n        \n    # Konversi dari RGB ke HSV\n    hsv_img = cv2.cvtColor(crop_img, cv2.COLOR_RGB2HSV)\n    \n    # 1. Rentang Warna Merah (Merah ada di dua ujung spektrum HSV)\n    lower_red1 = np.array([0, 50, 50])\n    upper_red1 = np.array([10, 255, 255])\n    lower_red2 = np.array([160, 50, 50])\n    upper_red2 = np.array([180, 255, 255])\n    \n    # 2. Rentang Warna Kuning\n    lower_yellow = np.array([15, 50, 50])\n    upper_yellow = np.array([35, 255, 255])\n    \n    # 3. Rentang Warna Hijau\n    lower_green = np.array([40, 50, 50])\n    upper_green = np.array([90, 255, 255])\n    \n    # Buat Masking (Saringan piksel)\n    mask_red1 = cv2.inRange(hsv_img, lower_red1, upper_red1)\n    mask_red2 = cv2.inRange(hsv_img, lower_red2, upper_red2)\n    mask_red = cv2.bitwise_or(mask_red1, mask_red2)\n    \n    mask_yellow = cv2.inRange(hsv_img, lower_yellow, upper_yellow)\n    mask_green = cv2.inRange(hsv_img, lower_green, upper_green)\n    \n    # Hitung jumlah piksel yang lolos saringan tiap warna\n    red_pixels = cv2.countNonZero(mask_red)\n    yellow_pixels = cv2.countNonZero(mask_yellow)\n    green_pixels = cv2.countNonZero(mask_green)\n    \n    # Cari warna dengan piksel paling dominan\n    max_pixels = max(red_pixels, yellow_pixels, green_pixels)\n    \n    if max_pixels == 0:\n        return \"Unknown\"\n    elif max_pixels == red_pixels:\n        return \"Red\"\n    elif max_pixels == yellow_pixels:\n        return \"Yellow\"\n    else:\n        return \"Green\"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import pandas as pd\nfrom tqdm import tqdm\nimport torch\nimport cv2\nimport base64\nfrom io import BytesIO\nfrom PIL import Image\nfrom IPython.display import HTML, display # Tambahan untuk render HTML di tabel\n\n# --- FUNGSI HELPER: UBAH GAMBAR KE HTML BASE64 ---\ndef crop_to_html_img(img_array):\n    \"\"\"Mengubah numpy array gambar menjadi tag <img> HTML.\"\"\"\n    if img_array.size == 0:\n        return \"N/A\" # Kalau gambar kosong\n    \n    # Ubah numpy array (RGB) ke format PIL Image\n    img_pil = Image.fromarray(img_array)\n    \n    # Simpan ke buffer memory sementara\n    buffer = BytesIO()\n    img_pil.save(buffer, format=\"JPEG\")\n    \n    # Encode ke string Base64\n    img_str = base64.b64encode(buffer.getvalue()).decode(\"utf-8\")\n    \n    # Kembalikan sebagai tag HTML (width diset 50px biar tabel ga kegedean)\n    return f'<img src=\"data:image/jpeg;base64,{img_str}\" width=\"50\" style=\"border-radius:4px; border: 1px solid #ccc;\"/>'\n\n# --- FUNGSI UTAMA GENERATE TABLE ---\ndef generate_prediction_table(model, dataset, device, threshold=0.5):\n    model.eval()\n    results = []\n\n    for img_index in tqdm(range(len(dataset)), desc=\"Mengekstrak Prediksi\"):\n        img_tensor, target = dataset[img_index]\n        filename = dataset.files[img_index] \n        \n        gt_labels = target['labels'].cpu().numpy()\n        has_real_traffic_light = 1 in gt_labels \n\n        img_display = img_tensor.permute(1, 2, 0).cpu().numpy()\n        img_display = (img_display * 255).astype(np.uint8)\n\n        with torch.no_grad():\n            prediction = model([img_tensor.to(device)])[0]\n\n        boxes = prediction['boxes'].cpu().numpy()\n        labels = prediction['labels'].cpu().numpy()\n        scores = prediction['scores'].cpu().numpy()\n\n        found_tl_in_pred = False\n\n        for i in range(len(boxes)):\n            if scores[i] >= threshold:\n                if labels[i] == 1: \n                    found_tl_in_pred = True\n                    bbox = boxes[i]\n                    xmin, ymin, xmax, ymax = map(int, bbox)\n                    \n                    # 1. Prediksi Warna HSV (Pakai fungsi lamamu)\n                    pred_color = detect_traffic_light_color(img_display, bbox)\n                    \n                    # 2. Ambil crop gambar dan ubah ke tag HTML\n                    crop_img = img_display[ymin:ymax, xmin:xmax]\n                    html_img = crop_to_html_img(crop_img)\n                    \n                    results.append({\n                        'id_image': filename,\n                        'gambar_crop': html_img, # Kolom baru berisi gambar!\n                        'hasil_prediksi_warna': pred_color,\n                        'confidence_score': round(float(scores[i]), 3),\n                        'label_asli': 'trafficlight',\n                        'bbox_prediksi': [xmin, ymin, xmax, ymax]\n                    })\n        \n        if has_real_traffic_light and not found_tl_in_pred:\n            results.append({\n                'id_image': filename,\n                'gambar_crop': 'Tidak Terdeteksi',\n                'hasil_prediksi_warna': 'Tidak Terdeteksi',\n                'confidence_score': 0.0,\n                'label_asli': 'trafficlight',\n                'bbox_prediksi': None\n            })\n\n    df_results = pd.DataFrame(results)\n    return df_results\n\n# --- CARA MENJALANKAN & MENAMPILKAN HASIL ---\nprint(\"Memulai proses ekstraksi\")\ndf_prediksi = generate_prediction_table(model, dataset, device, threshold=0.5)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T07:26:14.670348Z","iopub.execute_input":"2026-03-28T07:26:14.670768Z","iopub.status.idle":"2026-03-28T07:27:40.842961Z","shell.execute_reply.started":"2026-03-28T07:26:14.670739Z","shell.execute_reply":"2026-03-28T07:27:40.842342Z"}},"outputs":[{"name":"stdout","text":"Memulai proses ekstraksi\n","output_type":"stream"},{"name":"stderr","text":"Mengekstrak Prediksi: 100%|██████████| 877/877 [01:26<00:00, 10.18it/s]\n","output_type":"stream"}],"execution_count":8},{"cell_type":"code","source":"import os\n\nprint(\"Memperbaiki duplikasi id_image...\")\n\n# 1. Hitung urutan kemunculan tiap id_image (bakal jadi 1, 2, 3, dst untuk gambar yang sama)\nurutan = df_prediksi.groupby('id_image').cumcount() + 1\n\nid_baru = []\nfor filename, count in zip(df_prediksi['id_image'], urutan):\n    # 2. Pisahkan nama