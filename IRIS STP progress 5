n root.findall('object'):\n            name = obj.find('name').text\n            bbox = obj.find('bndbox')\n            xmin = int(bbox.find('xmin').text)\n            ymin = int(bbox.find('ymin').text)\n            xmax = int(bbox.find('xmax').text)\n            ymax = int(bbox.find('ymax').text)\n            \n            # Hitung fitur tambahan untuk EDA\n            obj_width = xmax - xmin\n            obj_height = ymax - ymin\n            area = obj_width * obj_height\n            center_x = xmin + (obj_width / 2)\n            center_y = ymin + (obj_height / 2)\n            \n            data.append({\n                'filename': filename,\n                'class': name,\n                'img_width': width,\n                'img_height': height,\n                'obj_width': obj_width,\n                'obj_height': obj_height,\n                'area': area,\n                'aspect_ratio': obj_width / obj_height,\n                'rel_center_x': center_x / width,  # Normalisasi 0-1\n                'rel_center_y': center_y / height, # Normalisasi 0-1\n                'rel_area': area / (width * height)\n            })\n    return pd.DataFrame(data)\n\n# Load Data\ndf = parse_xml(PATH_XML)\n\n# --- VISUALISASI ---\n\nplt.figure(figsize=(15, 10))\n\n# 1. Distribusi Kelas (Imbalance Check)\nplt.subplot(2, 2, 1)\nsns.countplot(data=df, y='class', order=df['class'].value_counts().index, palette='viridis')\nplt.title('Jumlah Objek per Kelas')\n\n# 2. Distribusi Ukuran Objek (Relative Area)\nplt.subplot(2, 2, 2)\nsns.histplot(df['rel_area'], bins=30, kde=True, color='orange')\nplt.title('Distribusi Luas Objek (Relatif terhadap Gambar)')\nplt.xlabel('Proporsi Luas (0.0 - 1.0)')\n\n# 3. Scatter Plot Lokasi Objek (Spatial Distribution)\nplt.subplot(2, 2, 3)\nplt.scatter(df['rel_center_x'], df['rel_center_y'], alpha=0.3, s=10, c='blue')\nplt.title('Sebaran Titik Tengah Objek (Spatial Heatmap)')\nplt.xlim(0, 1); plt.ylim(1, 0) # Invert Y karena koordinat gambar mulai dari