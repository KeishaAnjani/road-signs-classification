riginal\n\nDIR_IMG_BARU = '/kaggle/working/images_resized/'    # Folder gambar hasil resize\nDIR_XML_BARU = '/kaggle/working//annotations_resized/' # Folder XML hasil resize\n\n# Tentukan ukuran target (contoh: 640x640, standar umum untuk model deteksi)\nTARGET_WIDTH = 640\nTARGET_HEIGHT = 640\n\n# Buat folder output jika belum ada\nos.makedirs(DIR_IMG_BARU, exist_ok=True)\nos.makedirs(DIR_XML_BARU, exist_ok=True)\n\ndef preprocess_dataset():\n    total_files = 0\n    \n    for xml_file in os.listdir(DIR_XML_ASLI):\n        if not xml_file.endswith('.xml'): \n            continue\n            \n        # 2. BACA FILE XML\n        xml_path = os.path.join(DIR_XML_ASLI, xml_file)\n        tree = ET.parse(xml_path)\n        root = tree.getroot()\n        \n        # Ambil nama file gambar dari dalam XML\n        img_name = root.find('filename').text\n        img_path = os.path.join(DIR_IMG_ASLI, img_name)\n        \n        # 3. BACA GAMBAR DENGAN OPENCV\n        img = cv2.imread(img_path)\n        if img is None:\n            print(f\"Peringatan: Gambar {img_name} tidak ditemukan!\")\n            continue\n            \n        old_h, old_w = img.shape[:2]\n        \n        # Hitung rasio skala\n        scale_x = TARGET_WIDTH / old_w\n        scale_y = TARGET_HEIGHT / old_h\n        \n        # 4. RESIZE GAMBAR & SIMPAN\n        resized_img = cv2.resize(img, (TARGET_WIDTH, TARGET_HEIGHT))\n        cv2.imwrite(os.path.join(DIR_IMG_BARU, img_name), resized_img)\n        \n        # 5. UPDATE DATA DI XML\n        # Update meta ukuran gambar\n        root.find('size/width').text = str(TARGET_WIDTH)\n        root.find('size/height').text = str(TARGET_HEIGHT)\n        \n        # Update koordinat Bounding Box tiap objek\n        for obj in root.findall('object'):\n            bbox = obj.find('bndbox')\n            \n            xmin = float(bbox.find('xmin').text)\n            ymin = float(bbox.find('ymin').text)\n            xmax = float(bbox.find('xmax').text)\n            ymax = float(bbox.find('ymax').text)\n            \n            # Kalikan koordinat lama dengan rasio skala\n            new_xmin = int(xmin * scale_x)\n            new_ymin = int(ymin * scale_y)\n            new_xmax = int(xmax * scale_x)\n            new_ymax = int(ymax * scale_y)\n            \n            # Cegah koordinat keluar dari batas gambar (Out of Bounds)\n            new_xmin = max(0, min(new_xmin, TARGET_WIDTH))\n            new_xmax = max(0, min(new_xmax, TARGET_WIDTH))\n            new_ymin = max(0, min(new_ymin, TARGET_HEIGHT))\n            new_ymax = max(0, min(new_ymax, TARGET_HEIGHT))\n            \n            # Tulis koordinat baru ke XML\n            bbox.find('xmin').text = str(new_xmin)\n            bbox.find('ymin').text = str(new_ymin)\n            bbox.find('xmax').text = str(new_xmax)\n            bbox.find('ymax').text = str(new_ymax)\n            \n        # 6. SIMPAN XML BARU\n        new_xml_path = os.path.join(DIR_XML_BARU, xml_file)\n        tree.write(new_xml_path)\n        total_files += 1\n\n    print(f\"Preprocessing selesai! Total {total_files} data berhasil di-resize ke {TARGET_WIDTH}x{TARGET_HEIGHT}.\")\n\n# Jalankan fungsi\npreprocess_dataset()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T06:21:19.270275Z","iopub.execute_input":"2026-03-28T06:21:19.270934Z","iopub.status.idle":"2026-03-28T06:21:50.845884Z","shell.execute_reply.started":"2026-03-28T06:21:19.270906Z","shell.execute_reply":"2026-03-28T06:21:50.845012Z"}},"outputs":[{"name":"stdout","text":"Preprocessing selesai! Total 877 data berhasil di-resize ke 640x640.\n","output_type":"stream"}],"execution_count":4},{"cell_type":"code","source":"import os\nimport cv2\nimport torch\nimport torchvision\nimport numpy as np\nimport xml.etree.ElementTree as ET\nfrom torchvision.models.detection.faster_rcnn import FastRCNNPredictor\nfrom torch.utils.data import Dataset, DataLoader\nfrom sklearn.metrics import f1_score, confusion_matrix, classification_report\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom tqdm import tqdm\n\n# =====================================================================\n# 0. KONFIGURASI AWAL (FASE 1: KELAS DASAR)\n# =====================================================================\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n\n# Kelas asli dari dataset bawaan (tanpa warna)\nCLASSES = [\"trafficlight\", \"speedlimit\", \"crosswalk\", \"stop\"]\nEPOCHS = 5\nTHRESHOLD = 0.5  \n\n# Index label yang valid untuk dievaluasi (1 sampai 4)\nVALID_LABELS_IDX = list(range(1, len(CLASSES) + 1))\n\nprint(\"Mempersiapkan Dataset Dasar (Fase 1)...\")\n\n# =====================================================================\n# 1. DEFINISI DATASET & DATALOADER (MURNI DARI XML)\n# =====================================================================\nclass RoadDataset(Dataset):\n    def __init__(self, img_dir, xml_dir, classes):\n        self.img_dir = img_dir\n        self.xml_dir = xml_dir\n        self.files = [f for f in os.listdir(xml_dir) if f.endswith('.xml')]\n        self.classes = classes\n\n    def __len__(self):\n        return len(self.files)\n\n    def __getitem__(self, idx):\n        xml_file = self.files[idx]\n        tree = ET.parse(os.path.join(self.xml_dir, xml_file))\n        root = tree.getroot()\n\n        img_name = root.find('filename').text\n        img_path = os.path.join(self.img_dir, img_name)\n\n        img = cv2.imread(img_path)\n        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n        img = torch.tensor(img, dtype=torch.float32).permute(2,0,1) / 255.0\n\n        boxes, labels = [], []\n\n        # Ambil SEMUA rambu sesuai list CLASSES\n        for obj in root.findall('object'):\n            cls = obj.find('name').text\n            if cls in self.classes:\n                bbox = obj.find('bndbox')\n                xmin = float(bbox.find('xmin').text)\n                ymin = float(bbox.find('ymin').text)\n                xmax = float(bbox.find('xmax').text)\n                ymax = float(bbox.find('ymax').text)\n                boxes.append([xmin, ymin, xmax, ymax])\n                labels.append(self.classes.index(cls) + 1) \n\n        if len(boxes) == 0:\n            boxes = torch.empty((0, 4), dtype=torch.float32)\n            labels = torch.empty((0,), dtype=torch.int64)\n        else:\n            boxes = torch.as_tensor(boxes, dtype=torch.float32)\n            labels = torch.as_tensor(labels, dtype=torch.int64)\n\n        target = {\"boxes\": boxes, \"labels\": labels}\n        return img, target\n\ndef collate_fn(batch):\n    return tuple(zip(*batch))\n\ndataset = RoadDataset('/kaggle/working/images_resized', '/kaggle/working/annotations_resized', CLASSES)\nloader = DataLoader(dataset, batch_size=4, shuffle=True, collate_fn=collate_fn)\n\n# =====================================================================\n# 2. INISIALISASI MODEL FASTER R-CNN (BASE)\n# =====================================================================\nmodel = torchvision.models.detection.fasterrcnn_resnet50_fpn(pretrained=True)\nin_features = model.roi_heads.box_predictor.cls_score.in_features\nnum_classes = len(CLASSES) + 1 # 4 kelas + 1 background\nmodel.roi_heads.box_predictor = FastRCNNPredictor(in_features, num_classes)\nmodel.to(device)\n\noptimizer = torch.optim.Adam(model.parameters(), lr=1e-4)\nprint(\"Base Model berhasil dibangun! 🚀\")\n\n# =====================================================================\n# 3. TRAINING & EVALUATION LOOP\n# =====================================================================\nhistory_loss, history_f1 = [], []\nbest_f1 = 0.0\n\nprint(f\"\\nMulai Training Fase 1 untuk {EPOCHS} Epochs pakai Device: {device} ⚡\")\n\nfor epoch in range(EPOCHS):\n    # --- TRAIN PHASE ---\n    model.train()\n    total_loss = 0\n    \n    loop = tqdm(loader, desc=f\"Epoch {epoch+1}/{EPOCHS} [TRAIN]\", leave=False)\n    for imgs, targets in loop:\n        imgs = [img.to(device) for img in imgs]\n        targets = [{k: v.to(device) for k, v in t.items()} for t in targets]\n\n        loss_dict = model(imgs, targets)\n        loss = sum(loss for loss in loss_dict.values())\n\n        optimizer.zero_grad()\n        loss.backward()\n        optimizer.step()\n\n        total_loss += loss.item()\n        loop.set_postfix(loss=loss.item())\n        \n    avg_loss = total_loss / len(loader)\n    history_loss.append(avg_loss)\n\n    # --- EVALUATION PHASE ---\n    model.eval()\n    y_true_epoch, y_pred_epoch = [], []\n\n    with torch.no_grad():\n        for imgs, targets in loader: \n            imgs = [img.to(device) for img in imgs]\n            outputs = model(imgs)\n\n            for i, output in enumerate(outputs):\n                scores = output['scores'].cpu().numpy()\n                pred_labels = output['labels'].cpu().numpy()\n                \n                valid_preds = pred_labels[scores >= THRESHOLD].tolist()\n                true_labels = targets[i]['labels'].cpu().numpy().tolist()\n\n                valid_preds.sort()\n                true_labels.sort()\n                max_len = max(len(valid_preds), len(true_labels))\n                \n                valid_preds += [0] * (max_len - len(valid_preds))\n                true_labels += [0] * (max_len - len(true_labels))\n\n                y_pred_epoch.extend(valid_preds)\n                y_true_epoch.extend(true_labels)\n\n    # Hitung Macro F1 Score dengan IGNORING KELAS 0 (Background)\n    epoch_f1 = f1_score(y_true_epoch, y_pred_epoch, labels=VALID_LABELS_IDX, average='macro', zero_division=0)\n    history_f1.append(epoch_f1)\n    \n    print(f\"✅ Epoch {epoch+1} Selesai | Avg Loss: {avg_loss:.4f} | F1 Score: {epoch_f1:.4f}\")\n\n    if epoch_f1 > best_f1:\n        best_f1 = epoch_f1\n        # Nama file diubah jadi base_model biar ngga kecampur sama model retrain nanti\n        torch.save(model.state_dict(), '/kaggle/working/base_model.pth')\n        print(f\"🌟 Base Model terbaik baru disimpan! (F1 naik menjadi: {best_f1:.4f})\")\n\n# =====================================================================\n# 4. CLASSIFICATION REPORT & VISUALISASI\n# =====================================================================\nprint(\"\\n\" + \"=\"*50)\nprint(\"📊 FINAL CLASSIFICATION REPORT (BASE MODEL) 📊\")\nprint(\"=\"*50)\n\n# Print Laporan tanpa Background\nprint(classification_report(y_true_epoch, y_pred_epoch, labels=VALID_LABELS_IDX, target_names=CLASSES, zero_division=0))\n\n# Hitung Confusion Matrix tanpa Background\ncm = confusion_matrix(y_true_epoch, y_pred_epoch, labels=VALID_LABELS_IDX)\n\nplt.figure(figsize=(18, 5))\nplt.subplot(1, 3, 1)\nplt.plot(range(1, EPOCHS+1), history_loss, marker='o', linestyle='-', color='red', label='Training Loss')\nplt.title('Grafik Penurunan Loss')\nplt.xlabel('Epoch')\nplt.ylabel('Loss')\nplt.xticks(range(1, EPOCHS+1))\nplt.grid(True, linestyle='--', alpha=0.6)\nplt.legend()\n\nplt.subplot(1, 3, 2)\nplt.plot(range(1, EPOCHS+1), history_f1, marker='s', linestyle='-', color='green', label='F1 Score (Macro)')\nplt.title('Grafik Peningkatan F1 Score')\nplt.xlabel('Epoch')\nplt.ylabel('F1 Score')\nplt.xticks(range(1, EPOCHS+1))\nplt.ylim(0, 1.05)\nplt.grid(True, linestyle='--', alpha=0.6)\nplt.legend()\n\nplt.subplot(1, 3, 3)\nsns.heatmap(cm, annot=True, fmt='d', cmap='Blues', \n            xticklabels=CLASSES, \n            yticklabels=CLASSES)\nplt.title('Confusion Matrix (Fase 1 - 4 Kelas)')\nplt.xlabel('Predicted Label')\nplt.ylabel('True Label')\nplt.xticks(rotation=45)\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T06:21:50.846979Z","iopub.execute_input":"2026-03-28T06:21:50.847888Z","iopub.status.idle":"2026-03-28T06:45:26.208056Z","shell.execute_reply.started":"2026-03-28T06:21:50.847852Z","shell.execute_reply":"2026-03-28T06:45:26.207384Z"}},"outputs":[{"name":"stdout","text":"Mempersiapkan Dataset Dasar (Fase 1)...\n","output_type":"strea