t":null},{"cell_type":"code","source":"import pandas as pd\nimport ast\nimport torch\nimport torchvision\nfrom torchvision.models.detection import fasterrcnn_resnet50_fpn\nfrom torch.utils.data import Dataset, DataLoader\nimport xml.etree.ElementTree as ET\nimport os\nimport cv2\nimport numpy as np\nfrom sklearn.metrics import f1_score\nfrom tqdm import tqdm\n\n# --- 1. PERSIAPAN DATA KOREKSI DARI CSV ---\nprint(\"Membaca data koreksi dari CSV...\")\n# Sesuaikan nama file CSV dengan file yang sudah kamu edit!\ndf_koreksi = pd.read_csv('/kaggle/input/datasets/keishaanjani/tl-fix/hasil_prediksi_warna_tl_1.csv')\n\n# Buang data yang lampunya tidak terdeteksi atau unknown biar model ngga bingung\ndf_koreksi = df_koreksi[df_koreksi['hasil_prediksi_warna'].isin(['Red', 'Yellow', 'Green'])]\n\n# Ubah string \"[xmin, ymin, xmax, ymax]\" kembali jadi list beneran\ndf_koreksi['bbox_prediksi'] = df_koreksi['bbox_prediksi'].apply(ast.literal_eval)\n\n# Kelompokkan data berdasarkan nama file XML biar gampang dicari\nkoreksi_dict = {}\nfor _, row in df_koreksi.iterrows():\n    img_id = row['id_image']\n    if img_id not in koreksi_dict:\n        koreksi_dict[img_id] = []\n    koreksi_dict[img_id].append({\n        'color': row['hasil_prediksi_warna'].lower(), # jadi 'red', 'yellow', 'green'\n        'bbox': row['bbox_prediksi']\n    })\n\n# --- 2. UPDATE KELAS & BIKIN DATASET BARU ---\n# Sekarang kelasnya bertambah! Trafficlight kita pecah jadi 3 warna\nNEW_CLASSES = [\"red\", \"yellow\", \"green\", \"speedlimit\", \"crosswalk\", \"stop\"]\n\nclass RetrainRoadDataset(Dataset):\n    def __init__(self, img_dir, xml_dir, classes, koreksi_data):\n        self.img_dir = img_dir\n        self.xml_dir = xml_dir\n        self.files = [f for f in os.listdir(xml_dir) if f.endswith('.xml')]\n        self.classes = classes\n        self.koreksi_data = koreksi_data\n\n    def __len__(self):\n        return len(self.files)\n\n    def __getitem__(self, idx):\n        xml_file = self.files[idx]\n        tree = ET.parse(os.path.join(self.xml_dir, xml_file))\n        root = tree.getroot()\n\n        img_name = root.find('filename').text\n        img_path = os.path.join(self.img_dir, img_name)\n\n        img = cv2.imread(img_path)\n        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n        img = torch.tensor(img, dtype=torch.float32).permute(2,0,1) / 255.0\n\n        boxes = []\n        labels = []\n\n        # 1. Ambil anotasi rambu LAIN (selain traffic light) dari XML asli\n        for obj in root.findall('object'):\n            cls = obj.find('name').text\n            if cls in [\"speedlimit\", \"crosswalk\", \"stop\"]:\n                bbox = obj.find('bndbox')\n                xmin = float(bbox.find('xmin').text)\n                ymin = float(bbox.find('ymin').text)\n                xmax = float(bbox.find('xmax').text)\n                ymax = float(bbox.find('ymax').text)\n                boxes.append([xmin, ymin, xmax, ymax])\n                labels.append(self.classes.index(cls) + 1) \n\n        # 2. Ambil anotasi KHUSUS Traffic Light dari CSV yang sudah kamu koreksi\n        if xml_file in self.koreksi_data:\n            for tl in self.koreksi_data[xml_file]:\n                boxes.append(tl['bbox'])\n                labels.append(self.classes.index(tl['color']) + 1)\n\n        # Handle kasus jika gambar tidak punya objek sama sekali (kosong)\n        if len(boxes) == 0:\n            boxes = torch.empty((0, 4), dtype=torch.float32)\n            labels = torch.empty((0,), dtype=torch.int64)\n        else:\n            boxes = torch.as_tensor(boxes, dtype=torch.float32)\n            labels = torch.as_tensor(labels, dtype=torch.int64)\n\n        target = {\"boxes\": boxes, \"labels\": labels}\n        return img, target\n\n# --- 3. INISIALISASI MODEL & DATALOADER ---\nprint(\"Menyiapkan Dataset dan Model...\")\ndataset_retrain = RetrainRoadDataset(\n    '/kaggle/working/images_resized',\n    '/kaggle/working/annotations_resized',\n    NEW_CLASSES,\n    koreksi_dict\n)\n\ndef collate_fn(batch):\n    return tuple(zip(*batch))\n\nloader_retrain = DataLoader(dataset_retrain, batch_size=4, shuffle=True, collate_fn=collate_fn)\n\nmodel_retrain = fasterrcnn_resnet50_fpn(pretrained=True)\nnum_classes = len(NEW_CLASSES) + 1  # 6 kelas baru + 1 background\nin_features = model_retrain.roi_heads.box_predictor.cls_score.in_features\nmodel_retrain.roi_heads.box_predictor = torchvision.models.detection.faster_rcnn.FastRCNNPredictor(\n    in_features, num_classes\n)\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nmodel_retrain.to(device)\n\noptimizer = torch.optim.Adam(model_retrain.parameters(), lr=1e-4)\n\n# --- 4. TRAINING LOOP ---\nEPOCHS = 5\nprint(f\"Mulai Retraining untuk {EPOCHS} Epochs pakai Device: {device} ⚡\")\n\nfor epoch in range(EPOCHS):\n    model_retrain.train()\n    total_loss = 0\n\n    loop = tqdm(loader_retrain, desc=f\"Epoch {epoch+1}/{EPOCHS}\", leave=True)\n    for imgs, targets in loop:\n        imgs = [img.to(device) for img in imgs]\n        targets = [{k: v.to(device) for k, v in t.items()} for t in targets]\n\n        loss_dict = model_retrain(imgs, targets)\n        loss = sum(loss for loss in loss_dict.values())\n\n        optimizer.zero_grad()\n        loss.backward()\n        optimizer.step()\n\n        total_loss += loss.item()\n        loop.set_postfix(loss=loss.item())\n\n    print(f\"✅ Rata-rata Loss Epoch {epoch+1}: {total_loss/len(loader_retrain):.4f}\\n\")\n\n# --- 5. EVALUASI F1 SCORE ---\nprint(\"Menghitung F1 Score Evaluasi Akhir...\")\nmodel_retrain.eval()\n\ny_true_all = []\ny_pred_all = []\n\nthreshold = 0.5\n\nwith torch.no_grad():\n    for imgs, targets in tqdm(loader_retrain, desc=\"Evaluasi F1\"):\n        imgs = [img.to(device) for img in imgs]\n        outputs = model_retrain(imgs)\n\n        for i, output in enumerate(outputs):\n            # Ambil label prediksi yang skornya di atas threshold\n            scores = output['scores'].cpu().numpy()\n            pred_labels = output['labels'].cpu().numpy()\n            valid_preds = pred_labels[scores >= threshold].tolist()\n            \n            # Ambil label asli\n            true_labels = targets[i]['labels'].cpu().numpy().tolist()\n\n            # --- Trik Hitung F1 tanpa IoU Matching (Quick Classification Approximation) ---\n            # Urutkan label biar perbandingannya adil\n            valid_preds.sort()\n            true_labels.sort()\n\n            # Samakan panjang list dengan menambahkan 0 (Background / False Negative / False Positive)\n            max_len = max(len(valid_preds), len(true_labels))\n            valid_preds += [0] * (max_len - len(valid_preds))\n            true_labels += [0] * (max_len - len(true_labels))\n\n            y_pred_all.extend(valid_preds)\n            y_true_all.extend(true_labels)\n\n# Hitung Macro F1 Score (Menghitung performa rata-rata semua kelas)\nf1 = f1_score(y_true_all, y_pred_all, average='macro')\n\nprint(\"=\"*40)\nprint(f\"🏆 FINAL F1 SCORE (Macro): {f1:.4f} 🏆\")\nprint(\"=\"*40)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T07:29:57.302650Z","iopub.execute_input":"2026-03-28T07:29:57.303081Z","iopub.status.idle":"2026-03-28T07:47:21.268037Z","shell.execute_reply.started":"2026-03-28T07:29:57.303051Z","shell.execute_reply":"2026-03-28T07:47:21.267213Z"}},"outputs":[{"name":"stdout","text":"Membaca data koreksi dari CSV...\nMenyiapkan Dataset dan Model...\n","output_type":"stream"},{"name":"stderr","text":"/usr/local/lib/python3.12/dist-packages/torchvision/models/_utils.py:208: UserWarning: The parameter 'pretrained' is deprecated since 0.13 and may be removed in the future, please use 'weights' instead.\n  warnings.warn(\n/usr/local/lib/python3.12/dist-packages/torchvision/models/_utils.py:223: UserWarning: Arguments other than a weight enum or `None` for 'weights' are deprecated since 0.13 and may be removed in the future. The current behavior is equivalent to passing `weights=FasterRCNN_ResNet50_FPN_Weights.COCO_V1`. You can also use `weights=FasterRCNN_ResNet50_FPN_Weights.DEFAULT` to get the most up-to-date weights.\n  warnings.warn(msg)\n","output_type":"stream"},{"name":"stdout","text":"Mulai Retraining untuk 5 Epochs pakai Device: cuda ⚡\n","output_type":"stream"},{"name":"stderr","text":"Epoch 1/5: 100%|██████████| 220/220 [03:10<00:00,  1.15it/s, loss=0.124]  \n","output_type":"stream"},{"name":"stdout","text":"✅ Rata-rata Loss Epoch 1: 0.1386\n\n","output_type":"stream"},{"name":"stderr","text":"Epoch 2/5: 100%|██████████| 220/220 [03:10<00:00,  1.15it/s, loss=0.0368]\n","output_type":"stream"},{"name":"stdout","text":"✅ Rata-rata Loss Epoch 2: 0.0607\n\n","output_type":"stream"},{"name":"stderr","text":"Epoch 3/5: 100%|██████████| 220/220 [03:10<00:00,  1.15it/s, loss=0.0649]\n","output_type":"stream"},{"name":"stdout","text":"✅ Rata-rata Loss Epoch 3: 0.0540\n\n","output_type":"stream"},{"name":"stderr","text":"Epoch 4/5: 100%|██████████| 220/220 [03:10<00:00,  1.15it/s, loss=0.034] \n","output_type":"stream"},{"name":"stdout","text":"✅ Rata-rata Loss Epoch 4: 0.0418\n\n","output_type":"stream"},{"name":"stderr","text":"Epoch 5/5: 100%|██████████| 220/220 [03:10<00:00,  1.16it/s, loss=0.019]  \n","output_type":"stream"},{"name":"stdout","text":"✅ Rata-rata Loss Epoch 5: 0.0382\n\nMenghitung F1 Score Evaluasi Akhir...\n","output_type":"stream"},{"name":"stderr","text":"Evaluasi F1: 100%|██████████| 220/220 [01:30<00:00,  2.43it/s]","output_type":"stream"},{"name":"stdout","text":"========================================\n🏆 FINAL F1 SCORE (Macro): 0.7079 🏆\n========================================\n","output_type":"stream"},{"name":"stderr","text":"\n","output_type":"stream"}],"execution_count":12},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}
