{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":15407980,"datasetId":9856756,"databundleVersionId":16323917},{"sourceType":"datasetVersion","sourceId":1181356,"datasetId":671172,"databundleVersionId":1212442}],"dockerImageVersionId":31329,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"# 🚦 Pipeline Lanjutan: 2-Cabang Detection\n## Setelah Faster R-CNN → Traffic Light Color + Speedlimit Angka\n\n**Alur pipeline:**\n```\nFaster R-CNN\n    ├── trafficlight  → deteksi warna (HSV)  → trafficlight_red / _yellow / _green\n    ├── speedlimit   → deteksi angka (OCR)   → speedlimit_30 / _50 / _80 / dst\n    ├── stop         → stop (langsung)\n    └── crosswalk    → crosswalk (langsung)\n```","metadata":{}},{"cell_type":"code","source":"# ============================================================\n# CELL 1 — Install dependencies tambahan\n# ============================================================\n!pip install easyocr -q","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T08:18:41.445446Z","iopub.execute_input":"2026-03-28T08:18:41.446222Z","iopub.status.idle":"2026-03-28T08:18:45.512296Z","shell.execute_reply.started":"2026-03-28T08:18:41.446190Z","shell.execute_reply":"2026-03-28T08:18:45.511120Z"}},"outputs":[],"execution_count":4},{"cell_type":"code","source":"# ============================================================\n# CELL 2 — Import semua library yang dibutuhkan\n# ============================================================\nimport os\nimport re\nimport cv2\nimport torch\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as patches\nfrom PIL import Image\nimport easyocr\nimport torchvision\nimport xml.etree.ElementTree as ET\nfrom torchvision.models.detection import fasterrcnn_resnet50_fpn\nfrom torchvision.models.detection.faster_rcnn import FastRCNNPredictor\nimport warnings\nwarnings.filterwarnings('ignore')\n\ndevice = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\nprint(f\"Device: {device}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T08:18:45.514279Z","iopub.execute_input":"2026-03-28T08:18:45.514598Z","iopub.status.idle":"2026-03-28T08:18:45.521715Z","shell.execute_reply.started":"2026-03-28T08:18:45.514566Z","shell.execute_reply":"2026-03-28T08:18:45.521062Z"}},"outputs":[{"name":"stdout","text":"Device: cuda\n","output_type":"stream"}],"execution_count":5},{"cell_type":"code","source":"# ============================================================\n# CELL 3 — Load model Faster R-CNN yang sudah ditraining\n#           (model_retrain dari cell sebelumnya)\n# ============================================================\n# Kelas yang digunakan saat training (sesuai NEW_CLASSES di notebook aslimu)\nNEW_CLASSES = ['speedlimit', 'crosswalk', 'stop', 'trafficlight']\nNUM_CLASSES = len(NEW_CLASSES) + 1  # +1 background\n\n# Kalau kamu ingin load dari file .pth, uncomment baris ini:\nmodel_retrain = fasterrcnn_resnet50_fpn(weights=None)\nin_features = model_retrain.roi_heads.box_predictor.cls_score.in_features\nmodel_retrain.roi_heads.box_predictor = FastRCNNPredictor(in_features, NUM_CLASSES)\nmodel_retrain.load_state_dict(torch.load('/kaggle/input/datasets/keishaanjani/base-model/base_model.pth'))\nmodel_retrain.to(device)\n\n# Gunakan model_retrain yang masih ada di memori\nmodel_retrain.eval()\nprint(\"✅ Model Faster R-CNN siap digunakan\")\nprint(f\"Kelas: {NEW_CLASSES}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T08:18:45.522712Z","iopub.execute_input":"2026-03-28T08:18:45.523091Z","iopub.status.idle":"2026-03-28T08:18:49.592030Z","shell.execute_reply.started":"2026-03-28T08:18:45.523065Z","shell.execute_reply":"2026-03-28T08:18:49.591129Z"}},"outputs":[{"name":"stdout","text":"Downloading: \"https://download.pytorch.org/models/resnet50-0676ba61.pth\" to /root/.cache/torch/hub/checkpoints/resnet50-0676ba61.pth\n","output_type":"stream"},{"name":"stderr","text":"100%|██████████| 97.8M/97.8M [00:00<00:00, 181MB/s] \n","output_type":"stream"},{"name":"stdout","text":"✅ Model Faster R-CNN siap digunakan\nKelas: ['speedlimit', 'crosswalk', 'stop', 'trafficlight']\n","output_type":"stream"}],"execution_count":6},{"cell_type":"code","source":"# ============================================================\n# CELL 4 — Inisialisasi EasyOCR (untuk deteksi angka speedlimit)\n# ============================================================\nprint(\"Menginisialisasi EasyOCR (hanya angka)...\")\nocr_reader = easyocr.Reader(['en'], gpu=torch.cuda.is_available())\nprint(\"✅ EasyOCR siap\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T08:18:49.594162Z","iopub.execute_input":"2026-03-28T08:18:49.594500Z","iopub.status.idle":"2026-03-28T08:18:52.665240Z","shell.execute_reply.started":"2026-03-28T08:18:49.594473Z","shell.execute_reply":"2026-03-28T08:18:52.664478Z"}},"outputs":[{"name":"stdout","text":"Menginisialisasi EasyOCR (hanya angka)...\n✅ EasyOCR siap\n","output_type":"stream"}],"execution_count":7},{"cell_type":"code","source":"# ============================================================\n# CELL 5 — Fungsi cabang 1: Deteksi Warna Traffic Light (HSV)\n# ============================================================\ndef detect_traffic_light_color(img_bgr_crop):\n    \"\"\"\n    Mendeteksi warna traffic light dari crop gambar menggunakan HSV.\n    Return: 'red' | 'yellow' | 'green' | 'unknown'\n    \"\"\"\n    if img_bgr_crop is None or img_bgr_crop.size == 0:\n        return 'unknown'\n\n    hsv = cv2.cvtColor(img_bgr_crop, cv2.COLOR_BGR2HSV)\n\n    # Rentang warna HSV\n    masks = {\n        'red': (\n            cv2.inRange(hsv, np.array([0, 100, 100]),   np.array([10, 255, 255])) |\n            cv2.inRange(hsv, np.array([160, 100, 100]), np.array([180, 255, 255]))\n        ),\n        'yellow': cv2.inRange(hsv, np.array([18, 100, 100]), np.array([35, 255, 255])),\n        'green':  cv2.inRange(hsv, np.array([40, 50, 50]),   np.array([90, 255, 255])),\n    }\n\n    counts = {color: cv2.countNonZero(mask) for color, mask in masks.items()}\n    best_color = max(counts, key=counts.get)\n\n    # Hanya return kalau jumlah piksel cukup signifikan\n    if counts[best_color] < 30:\n        return 'unknown'\n    return best_color\n\nprint(\"✅ Fungsi detect_traffic_light_color siap\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T08:18:52.666278Z","iopub.execute_input":"2026-03-28T08:18:52.666554Z","iopub.status.idle":"2026-03-28T08:18:52.676246Z","shell.execute_reply.started":"2026-03-28T08:18:52.666516Z","shell.execute_reply":"2026-03-28T08:18:52.675317Z"}},"outputs":[{"name":"stdout","text":"✅ Fungsi detect_traffic_light_color siap\n","output_type":"stream"}],"execution_count":8},{"cell_type":"code","source":"# ============================================================\n# CELL 6 — Fungsi cabang 2: Deteksi Angka Speedlimit (OCR)\n# ============================================================\n# Daftar angka speedlimit yang valid\nVALID_SPEEDS = [20, 30, 50, 60, 70, 80, 100, 120]\n\ndef preprocess_speedlimit_crop(img_bgr_crop):\n    \"\"\"\n    Preprocessing crop speedlimit agar angka lebih mudah dibaca OCR.\n    \"\"\"\n    gray = cv2.cvtColor(img_bgr_crop, cv2.COLOR_BGR2GRAY)\n    # Resize agar lebih besar (bantu OCR)\n    resized = cv2.resize(gray, None, fx=2, fy=2, interpolation=cv2.INTER_CUBIC)\n    # Threshold adaptif untuk binarisasi\n    thresh = cv2.adaptiveThreshold(\n        resized, 255,\n        cv2.ADAPTIVE_THRESH_GAUSSIAN_C,\n        cv2.THRESH_BINARY_INV, 11, 2\n    )\n    return thresh\n\ndef detect_speedlimit_number(img_bgr_crop):\n    \"\"\"\n    Membaca angka speedlimit dari crop gambar menggunakan EasyOCR.\n    Return: angka (int) atau None\n    \"\"\"\n    if img_bgr_crop is None or img_bgr_crop.size == 0:\n        return None\n\n    preprocessed = preprocess_speedlimit_crop(img_bgr_crop)\n\n    # EasyOCR baca angka saja\n    results = ocr_reader.readtext(\n        preprocessed,\n        allowlist='0123456789',\n        detail=1\n    )\n\n    detected_numbers = []\n    for (bbox_ocr, text, confidence) in results:\n        if confidence > 0.3:\n            nums = re.findall(r'\\d+', text)\n            for n in nums:\n                detected_numbers.append(int(n))\n\n    if not detected_numbers:\n        return None\n\n    # Pilih angka yang paling mendekati nilai speedlimit valid\n    def closest_valid(num):\n        return min(VALID_SPEEDS, key=lambda x: abs(x - num))\n\n    # Ambil angka yang paling sering muncul\n    mapped = [closest_valid(n) for n in detected_numbers]\n    final_speed = max(set(mapped), key=mapped.count)\n    return final_speed\n\nprint(\"✅ Fungsi detect_speedlimit_number siap\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T08:18:52.677390Z","iopub.execute_input":"2026-03-28T08:18:52.677613Z","iopub.status.idle":"2026-03-28T08:18:52.934400Z","shell.execute_reply.started":"2026-03-28T08:18:52.677591Z","shell.execute_reply":"2026-03-28T08:18:52.933396Z"}},"outputs":[{"name":"stdout","text":"✅ Fungsi detect_speedlimit_number siap\n","output_type":"stream"}],"execution_count":9},{"cell_type":"code","source":"# ============================================================\n# CELL 7 — Fungsi pipeline utama: predict 1 gambar → label final\n# ============================================================\nSCORE_THRESHOLD = 0.5  # Confidence minimum Faster R-CNN\n\ndef predict_image(img_path, model, class_names, score_thresh=SCORE_THRESHOLD):\n    \"\"\"\n    Pipeline lengkap untuk 1 gambar:\n    1. Faster R-CNN → bounding box + kelas dasar\n    2. Cabang traffic light → deteksi warna\n    3. Cabang speedlimit   → deteksi angka\n    4. Return list deteksi dengan label final\n    \"\"\"\n    # Load gambar\n    img_bgr = cv2.imread(img_path)\n    if img_bgr is None:\n        return []\n\n    img_rgb = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2RGB)\n    img_tensor = torch.tensor(img_rgb, dtype=torch.float32).permute(2,0,1) / 255.0\n    img_tensor = img_tensor.unsqueeze(0).to(device)\n\n    # Faster R-CNN inference\n    with torch.no_grad():\n        output = model(img_tensor)[0]\n\n    boxes   = output['boxes'].cpu().numpy()\n    labels  = output['labels'].cpu().numpy()\n    scores  = output['scores'].cpu().numpy()\n\n    detections = []\n\n    for box, label_idx, score in zip(boxes, labels, scores):\n        if score < score_thresh:\n            continue\n\n        # label_idx: 1-based (0 = background)\n        base_class = class_names[label_idx - 1] if 1 <= label_idx <= len(class_names) else 'unknown'\n\n        xmin, ymin, xmax, ymax = map(int, box)\n        # Clip ke batas gambar\n        h, w = img_bgr.shape[:2]\n        xmin, ymin = max(0, xmin), max(0, ymin)\n        xmax, ymax = min(w, xmax), min(h, ymax)\n\n        crop = img_bgr[ymin:ymax, xmin:xmax]\n\n        # ---- CABANG PIPELINE ----\n        if base_class == 'trafficlight':\n            color = detect_traffic_light_color(crop)\n            final_label = f'trafficlight_{color}'\n\n        elif base_class == 'speedlimit':\n            number = detect_speedlimit_number(crop)\n            if number is not None:\n                final_label = f'speedlimit_{number}'\n            else:\n                final_label = 'speedlimit_unknown'\n\n        else:\n            # stop, crosswalk → apa adanya\n            final_label = base_class\n\n        detections.append({\n            'base_class': base_class,\n            'final_label': final_label,\n            'confidence': round(float(score), 4),\n            'xmin': xmin, 'ymin': ymin,\n            'xmax': xmax, 'ymax': ymax\n        })\n\n    return detections\n\nprint(\"✅ Fungsi predict_image siap\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T08:18:52.935487Z","iopub.execute_input":"2026-03-28T08:18:52.935805Z","iopub.status.idle":"2026-03-28T08:18:52.953440Z","shell.execute_reply.started":"2026-03-28T08:18:52.935767Z","shell.execute_reply":"2026-03-28T08:18:52.952611Z"}},"outputs":[{"name":"stdout","text":"✅ Fungsi predict_image siap\n","output_type":"stream"}],"execution_count":10},{"cell_type":"code","source":"import os\nimport cv2\nimport xml.etree.ElementTree as ET\n\n# --- 1. KONFIGURASI PATH & TARGET UKURAN ---\nDIR_IMG_ASLI = '/kaggle/input/datasets/andrewmvd/road-sign-detection/images'            # Folder gambar original\nDIR_XML_ASLI = '/kaggle/input/datasets/andrewmvd/road-sign-detection/annotations'       # Folder XML original\n\nDIR_IMG_BARU = '/kaggle/working/images_resized/'    # Folder gambar hasil resize\nDIR_XML_BARU = '/kaggle/working//annotations_resized/' # Folder XML hasil resize\n\n# Tentukan ukuran target (contoh: 640x640, standar umum untuk model deteksi)\nTARGET_WIDTH = 640\nTARGET_HEIGHT = 640\n\n# Buat folder output jika belum ada\nos.makedirs(DIR_IMG_BARU, exist_ok=True)\nos.makedirs(DIR_XML_BARU, exist_ok=True)\n\ndef preprocess_dataset():\n    total_files = 0\n    \n    for xml_file in os.listdir(DIR_XML_ASLI):\n        if not xml_file.endswith('.xml'): \n            continue\n            \n        # 2. BACA FILE XML\n        xml_path = os.path.join(DIR_XML_ASLI, xml_file)\n        tree = ET.parse(xml_path)\n        root = tree.getroot()\n        \n        # Ambil nama file gambar dari dalam XML\n        img_name = root.find('filename').text\n        img_path = os.path.join(DIR_IMG_ASLI, img_name)\n        \n        # 3. BACA GAMBAR DENGAN OPENCV\n        img = cv2.imread(img_path)\n        if img is None:\n            print(f\"Peringatan: Gambar {img_name} tidak ditemukan!\")\n            continue\n            \n        old_h, old_w = img.shape[:2]\n        \n        # Hitung rasio skala\n        scale_x = TARGET_WIDTH / old_w\n        scale_y = TARGET_HEIGHT / old_h\n        \n        # 4. RESIZE GAMBAR & SIMPAN\n        resized_img = cv2.resize(img, (TARGET_WIDTH, TARGET_HEIGHT))\n        cv2.imwrite(os.path.join(DIR_IMG_BARU, img_name), resized_img)\n        \n        # 5. UPDATE DATA DI XML\n        # Update meta ukuran gambar\n        root.find('size/width').text = str(TARGET_WIDTH)\n        root.find('size/height').text = str(TARGET_HEIGHT)\n        \n        # Update koordinat Bounding Box tiap objek\n        for obj in root.findall('object'):\n            bbox = obj.find('bndbox')\n            \n            xmin = float(bbox.find('xmin').text)\n            ymin = float(bbox.find('ymin').text)\n            xmax = float(bbox.find('xmax').text)\n            ymax = float(bbox.find('ymax').text)\n            \n            # Kalikan koordinat lama dengan rasio skala\n            new_xmin = int(xmin * scale_x)\n            new_ymin = int(ymin * scale_y)\n            new_xmax = int(xmax * scale_x)\n            new_ymax = int(ymax * scale_y)\n            \n            # Cegah koordinat keluar dari batas gambar (Out of Bounds)\n            new_xmin = max(0, min(new_xmin, TARGET_WIDTH))\n            new_xmax = max(0, min(new_xmax, TARGET_WIDTH))\n            new_ymin = max(0, min(new_ymin, TARGET_HEIGHT))\n            new_ymax = max(0, min(new_ymax, TARGET_HEIGHT))\n            \n            # Tulis koordinat baru ke XML\n            bbox.find('xmin').text = str(new_xmin)\n            bbox.find('ymin').text = str(new_ymin)\n            bbox.find('xmax').text = str(new_xmax)\n            bbox.find('ymax').text = str(new_ymax)\n            \n        # 6. SIMPAN XML BARU\n        new_xml_path = os.path.join(DIR_XML_BARU, xml_file)\n        tree.write(new_xml_path)\n        total_files += 1\n\n    print(f\"Preprocessing selesai! Total {total_files} data berhasil di-resize ke {TARGET_WIDTH}x{TARGET_HEIGHT}.\")\n\n# Jalankan fungsi\npreprocess_dataset()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-28T08:22:14.664792Z","iopub.execute_input":"2026-03-28T08:22:14.665724Z","iopub.status.idle":"2026-03-28T08:23:00.698475Z","shell.execute_reply.started":"2026-03-28T08:22:14.665687Z","shell.execute_reply":"2026-03-28T08:23:00.697756Z"}},"outputs":[{"name":"stdout","text":"Preprocessing selesai! Total 877 data berhasil di-resize ke 640x640.\n","output_type":"stream"}],"execution_count":12},{"cell_type":"code","source":"# ============================================================\n# CELL 8 — Jalankan pipeline ke semua gambar di folder val/test\n# ============================================================\nfrom tqdm import tqdm\n\n# Path folder gambar yang ingin diprediksi\n# Ganti sesuai folder kamu (bisa val, test, atau semua)\nIMG_FOLDER = '/kaggle/working/images_resized'\n\nall_img_files = [\n    f for f in os.listdir(IMG_FOLDER)\n    if f.lower().endswith(('.jpg', '.jpeg', '.png'))\n]\n\n# Batasi sample untuk demo (hapus [:50] untuk semua gambar)\nall_img_files = all_img_files[:50]\n\nprint(f\"Total gambar yang akan diprediksi: {len(all_img_files)}\")\n\nall_results = []\n\nfor img_file in tqdm(all_img_files, desc=\"Prediksi gambar\"):\n    img_path = os.path.join(IMG_FOLDER, img_file)\n    dets = predict_image(img_path, model_retrain, NEW_CLASSES)\n\n    if len(dets) == 0:\n        all_results.append({\n            'filename': img_file,\n            'base_class': 'none',\n            'final_label': 'no_detection',\n            'confidence': 0.0,\n            'xmin': None, 'ymin': None,\n            'xmax': None, 'ymax': None\n        })\n    else:\n        for det in dets:\n            all_results.append({'filename': img_file, **det})\n\ndf_results = pd.DataFrame(all